---
layout: layouts/layout.liquid
---

<main>
  {{ content }}
</main>

<aside class="group-portfolio group-portfolio-featured">
  <h2>Featured</h2>
  <ul class="list-portfolio">
    {% for item in collections.featured limit:3 %}
      <li>
        <a href="{{ item.url }}">
          <p><img src="{{item.data.images[0].image}}"></p>
          <p>{{ item.data.title }}</p>
        </a>
      </li>
    {% endfor %}
  </ul>
</aside>

<aside class="group-portfolio group-portfolio-latest">
  <h2>Latest</h2>
  <ul class="list-portfolio">
    {% for item in collections.portfolio limit:3 %}
      <li>
        <a href="{{ item.url }}">
          <p><img src="{{item.data.images[0].image}}"></p>
          <p>{{ item.data.title }}</p>
        </a>
      </li>
    {% endfor %}
  </ul>
</aside>
