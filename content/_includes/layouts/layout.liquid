<!doctype html>
<html lang="en">

<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{{ title }} - Sonny Craft</title>
  <link rel="stylesheet" href="css/style.css">
  <meta name="description" content="">

  {% comment %} <meta property="og:title" content=""> {% endcomment %}
  {% comment %} <meta property="og:type" content=""> {% endcomment %}
  {% comment %} <meta property="og:url" content=""> {% endcomment %}
  {% comment %} <meta property="og:image" content=""> {% endcomment %}
  {% comment %} <meta property="og:image:alt" content=""> {% endcomment %}

  {% comment %} <link rel="icon" href="/favicon.ico" sizes="any"> {% endcomment %}
  {% comment %} <link rel="icon" href="/icon.svg" type="image/svg+xml"> {% endcomment %}
  {% comment %} <link rel="apple-touch-icon" href="icon.png"> {% endcomment %}

  {% comment %} <link rel="manifest" href="site.webmanifest"> {% endcomment %}
  {% comment %} <meta name="theme-color" content="#fafafa"> {% endcomment %}
</head>

<body>

  {{ content }}

</body>

</html>
